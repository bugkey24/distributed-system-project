# Distributed System - Centralized Environment Template
# ========================================================
# Copy this file to .env and fill in your secure credentials

# App Configuration
APP_NAME="Distributed System"
APP_ENV=local
APP_KEY=base64:GENERATE_YOUR_OWN_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration (Shared across all backends)
MYSQL_ROOT_PASSWORD=
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=distributed_db
DB_USERNAME=laravel
DB_PASSWORD=

# Performance / Nginx
CLIENT_MAX_BODY_SIZE=10M
PROXY_READ_TIMEOUT=60s
